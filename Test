-- Waypoints System
-- ========================================
local function loadWaypoints()
    pcall(function()
        if isfile(waypointFile) then
            local data = readfile(waypointFile)
            waypoints = HttpService:JSONDecode(data)
        end
    end)
end

local function saveWaypoints()
    pcall(function()
        local data = HttpService:JSONEncode(waypoints)
        writefile(waypointFile, data)
    end)
end

local function refreshWaypointList(dropdown)
    waypointNames = {}
    for name in pairs(waypoints) do
        table.insert(waypointNames, name)
    end
    table.sort(waypointNames)
    if dropdown then
        dropdown:Refresh(waypointNames)
    end
end

local function teleportTo(targetCFrame, callback)
    local hrp = getRootPart()
    if not hrp then
        WindUI:Notify({ Title = "Error", Content = "Character not found", Icon = "alert-circle" })
        return
    end

    if teleportMethod == "Instant" then
        hrp.CFrame = targetCFrame
        if callback then callback() end
    elseif teleportMethod == "Tween" then
        if isTweening then return end
        isTweening = true

        local wasNoClipEnabled = noClipEnabled
        if not noClipEnabled then
            toggleNoClip(true)
        end

        local distance = (targetCFrame.Position - hrp.Position).Magnitude
        local tweenTime = distance / tweenSpeed

        local tween = TweenService:Create(hrp, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
        
        tween.Completed:Connect(function()
            isTweening = false
            if not wasNoClipEnabled then
                toggleNoClip(false)
            end
            if callback then callback() end
        end)
        
        tween:Play()
        
        WindUI:Notify({
            Title = "Teleporting",
            Content = string.format("%.0f studs (~%.1fs)", distance, tweenTime),
            Icon = "navigation",
        })
    end
end

