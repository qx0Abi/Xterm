-- ESP Functions
local function createESP(player)
    if player == LocalPlayer then return end
    task.spawn(function()
        repeat task.wait() until player.Character
        local char = player.Character
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if not hrp then return end

        local billboard = Instance.new("BillboardGui")
        billboard.Name = "ESP"
        billboard.Adornee = hrp
        billboard.Size = UDim2.new(0, 140, 0, 50)
        billboard.StudsOffset = Vector3.new(0, 3, 0)
        billboard.AlwaysOnTop = true
        billboard.Parent = hrp

        local label = Instance.new("TextLabel")
        label.Size = UDim2.new(1, 0, 1, 0)
        label.BackgroundTransparency = 1
        label.Text = player.Name
        label.TextColor3 = Color3.fromRGB(0, 255, 128)
        label.TextStrokeTransparency = 0
        label.TextScaled = true
        label.Font = Enum.Font.GothamBold
        label.Parent = billboard

        local highlight = Instance.new("Highlight")
        highlight.Adornee = char
        highlight.FillColor = Color3.fromRGB(0, 255, 128)
        highlight.OutlineColor = Color3.new(1,1,1)
        highlight.FillTransparency = 0.5
        highlight.Parent = char

        espObjects[player] = {billboard, highlight}
    end)
end

local function removeESP(player)
    local objs = espObjects[player]
    if objs then
        for _, obj in pairs(objs) do
            if obj then obj:Destroy() end
        end
        espObjects[player] = nil
    end
end

local function toggleESP(v)
    espEnabled = v
    if v then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then createESP(player) end
        end
    else
        for player, _ in pairs(espObjects) do
            removeESP(player)
        end
    end
end

-- NoClip
local function toggleNoClip(v)
    noClipEnabled = v
    if v then
        noClipConnection = RunService.Stepped:Connect(function()
            local char = getCharacter()
            if char then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if noClipConnection then noClipConnection:Disconnect() end
    end
end

-- Teleport
local function teleportTo(cf, cb)
    local hrp = getRootPart()
    if not hrp then return end

    if teleportMethod == "Instant" then
        hrp.CFrame = cf
        if cb then cb() end
        return
    end

    if isTweening then return end
    isTweening = true

    local wasNoClip = noClipEnabled
    if not wasNoClip then toggleNoClip(true) end

    local dist = (cf.Position - hrp.Position).Magnitude
    local time = dist / tweenSpeed

    local ti = TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(hrp, ti, {CFrame = cf})

    tween.Completed:Connect(function()
        isTweening = false
        if not wasNoClip then toggleNoClip(false) end
        if cb then cb() end
    end)
    tween:Play()
end

-- Loop TP
local function toggleLoopTp(v)
    loopTpEnabled = v
    if v and loopTpTarget then
        if loopTpConnection then loopTpConnection:Disconnect() end
        loopTpConnection = RunService.Heartbeat:Connect(function()
            local target = Players:FindFirstChild(loopTpTarget)
            if target and target.Character then
                local th = target.Character:FindFirstChild("HumanoidRootPart")
                local mh = getRootPart()
                if th and mh then
                    mh.CFrame = th.CFrame * CFrame.new(0, 5, 0)
                end
            end
        end)
    else
        if loopTpConnection then loopTpConnection:Disconnect() end
    end
end

-- Freecam
local function toggleFreecam(v)
    freecamEnabled = v
    local cam = workspace.CurrentCamera
    if v then
        if not freecamTarget then return end
        originalCamera = cam.CameraType
        cam.CameraType = Enum.CameraType.Scriptable
        freecamConnection = RunService.RenderStepped:Connect(function()
            local target = Players:FindFirstChild(freecamTarget)
            if target and target.Character then
                local head = target.Character.Head
                if head then
                    cam.CFrame = CFrame.new(head.Position + Vector3.new(0, 5, 10), head.Position)
                end
            end
        end)
    else
        if freecamConnection then freecamConnection:Disconnect() end
        cam.CameraType = originalCamera or Enum.CameraType.Custom
    end
end

