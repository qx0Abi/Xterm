-- Quick TP Functions (from your original script)
local teleportMethod = "Instant"
local tweenSpeed = 50
local isTweening = false

local function teleportTo(cf, cb)
    local hrp = getRootPart()
    if not hrp then return end

    if teleportMethod == "Instant" then
        hrp.CFrame = cf
        if cb then cb() end
        return
    end

    if isTweening then return end
    isTweening = true

    local dist = (cf.Position - hrp.Position).Magnitude
    local time = dist / tweenSpeed

    local ti = TweenInfo.new(time, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tween = TweenService:Create(hrp, ti, {CFrame = cf})

    tween.Completed:Connect(function()
        isTweening = false
        if cb then cb() end
    end)
    tween:Play()
end

